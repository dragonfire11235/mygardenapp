@@ -0,0 +1,23 @@
+// Ordnet einen Lumi-Tipp bzw. den aktuellen Navigationsbereich einer "Stimmung"
+// zu, damit das Maskottchen (LumiAvatar) passend sein Aussehen wechseln kann.
+
+export type LumiMood = 'weather' | 'devices' | 'diary' | 'plants' | 'beds' | 'tasks' | 'idle'
+
+const WEATHER_MARKERS = ['❄️', '🌧️', '💧']
+const DIARY_MARKERS = ['📖', '📷', '🦋']
+
+export function lumiMoodForTip(tip: string): LumiMood {
+  if (WEATHER_MARKERS.some((m) => tip.includes(m))) return 'weather'
+  if (DIARY_MARKERS.some((m) => tip.includes(m))) return 'diary'
+  return 'idle'
+}
+
+/** Ordnet den aktuellen Router-Pfad einem Nav-Bereich zu (für den Sidebar-Begleiter). */
+export function lumiMoodForRoute(path: string): LumiMood {
+  if (path.startsWith('/pflanzen')) return 'plants'
+  if (path.startsWith('/beete')) return 'beds'
+  if (path.startsWith('/aufgaben')) return 'tasks'
+  if (path.startsWith('/geraete')) return 'devices'
+  if (path.startsWith('/tagebuch') || path.startsWith('/entdeckungen')) return 'diary'
+  return 'idle'
+}
