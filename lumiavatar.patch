--- /dev/null
+++ b/src/shared/LumiAvatar.vue
@@ -0,0 +1,41 @@
+<script setup lang="ts">
+import { computed } from 'vue'
+import type { LumiMood } from '../features/dashboard/lumiMood'
+
+const props = withDefaults(defineProps<{ mood?: LumiMood; alt?: string }>(), {
+  mood: 'idle',
+  alt: 'Lumi',
+})
+
+// Welches Mascot-Bild zu welcher Stimmung gehört. Wird von mehreren Stellen
+// verwendet (Dashboard-Hero, künftig auch Geräte-Seite/KI-Assistent), damit
+// Lumi überall dieselben, konsistenten Ausdrücke zeigt.
+const MOOD_ASSETS: Record<LumiMood, string> = {
+  weather: 'lumi-watering.png',
+  devices: 'lumi-question.png',
+  diary: 'lumi-hug.png',
+  plants: 'lumi-pot.png',
+  beds: 'lumi-wanderer.png',
+  tasks: 'lumi-cheer.png',
+  idle: 'lumi-hero.png',
+}
+
+const src = computed(() => `${import.meta.env.BASE_URL}lumi/mascot/${MOOD_ASSETS[props.mood]}`)
+</script>
+
+<template>
+  <Transition name="lumi-fade" mode="out-in">
+    <img :key="mood" :src="src" :alt="alt" class="lumi-avatar" />
+  </Transition>
+</template>
+
+<style scoped>
+.lumi-fade-enter-active,
+.lumi-fade-leave-active {
+  transition: opacity 0.2s ease;
+}
+.lumi-fade-enter-from,
+.lumi-fade-leave-to {
+  opacity: 0;
+}
+</style>
