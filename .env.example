# Supabase-Zugang — Werte aus dem Dashboard: Project Settings → API.
# Kopiere diese Datei zu .env und trage deine Werte ein (.env ist gitignored).
# Der Publishable/Anon-Key ist client-öffentlich (RLS schützt die Daten).
# Den service_role-Key NIEMALS hier oder in VITE_-Variablen ablegen.
VITE_SUPABASE_URL=https://<dein-projekt>.supabase.co
VITE_SUPABASE_ANON_KEY=<dein-publishable-oder-anon-key>
